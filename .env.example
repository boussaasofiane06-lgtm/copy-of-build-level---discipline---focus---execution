# Render / production runtime
NODE_ENV=production
PORT=3000
DATABASE_URL=mysql://user:password@host:3306/database
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD_HASH=generate-with-pnpm-hash-password

# Optional when the frontend is hosted on another origin.
# Use comma-separated origins if needed.
CORS_ORIGIN=https://your-site.example
FRONTEND_URL=https://your-site.example

# Payments
STRIPE_SECRET_KEY=sk_live_or_test_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key
PAYPAL_CLIENT_ID=paypal-client-id
PAYPAL_CLIENT_SECRET=paypal-client-secret
PAYPAL_ENV=sandbox
VITE_PAYPAL_CLIENT_ID=paypal-client-id

# Optional OAuth / platform integrations
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
