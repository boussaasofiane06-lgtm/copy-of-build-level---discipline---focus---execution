# Database (Railway MySQL)
DATABASE_URL=mysql://root:password@yamanote.proxy.rlwy.net:11501/railway

# Admin password hash (generate with: node scripts/hash-password.js yourpassword)
ADMIN_PASSWORD_HASH=salt:hashedhex

# JWT secret for admin sessions (generate a random 64-char string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://your-site.pages.dev

# Node environment
NODE_ENV=production
